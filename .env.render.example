# ====================================================
# VARIABLES DE ENTORNO PARA RENDER - Condominio API
# ====================================================
# Copia estos valores en Render Dashboard → Environment
# NUNCA subas este archivo a GitHub con valores reales
# ====================================================

# ====================================================
# MYSQL DATABASE CONFIGURATION
# ====================================================
# Obtén estas credenciales de tu proveedor MySQL:
# - FreeSQLDatabase: https://www.freesqldatabase.com/
# - db4free: https://db4free.net/
# - Railway: https://railway.app/

DB_SERVER=sql.freesqldatabase.com
DB_NAME=sql12345678
DB_USER=sql12345678
DB_PASSWORD=tu_password_mysql_aqui

# ====================================================
# JWT CONFIGURATION
# ====================================================
# Genera una clave segura con:
# PowerShell: .\prepare-render.ps1 -GenerateJWT
# O manualmente: mínimo 32 caracteres aleatorios

JWT_SECRET_KEY=clave_super_secreta_para_jwt_1234567890_minimo_32_caracteres

# ====================================================
# CORS CONFIGURATION
# ====================================================
# En desarrollo: usa "*"
# En producción: especifica tu dominio frontend
# Ejemplo: https://mi-app-frontend.vercel.app

CORS_ALLOWED_ORIGIN=*

# ====================================================
# LOGGING CONFIGURATION
# ====================================================
# Render usa /tmp para archivos temporales
# Los logs se pueden ver en Render Dashboard → Logs

LOG_PATH=/tmp/logs/log-.txt

# ====================================================
# ASP.NET CORE CONFIGURATION
# ====================================================

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ====================================================
# INSTRUCCIONES PARA CONFIGURAR EN RENDER:
# ====================================================
# 
# 1. Ve a Render Dashboard: https://dashboard.render.com/
# 2. Selecciona tu servicio "condominio-api"
# 3. Click en "Environment" (tab en la parte superior)
# 4. Para cada variable:
#    a. Click en "Add Environment Variable"
#    b. Key: nombre de la variable (ej: DB_SERVER)
#    c. Value: valor de la variable
# 5. Click en "Save Changes"
# 6. Render reiniciará automáticamente tu servicio
#
# ====================================================
# EJEMPLO DE VALORES REALES (FreeSQLDatabase):
# ====================================================
#
# DB_SERVER=sql.freesqldatabase.com
# DB_NAME=sql12654321
# DB_USER=sql12654321
# DB_PASSWORD=xY9mK2pL4nQ7wE
# JWT_SECRET_KEY=a8b9c0d1e2f3g4h5i6j7k8l9m0n1o2p3q4r5s6t7u8v9w0x1y2z3a4b5c6d7e8f9
# CORS_ALLOWED_ORIGIN=*
# LOG_PATH=/tmp/logs/log-.txt
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:8080
#
# ====================================================
